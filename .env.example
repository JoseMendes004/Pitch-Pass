# ============ API (apps/api/.env) ============
DATABASE_URL="postgresql://user:password@localhost:5432/pitchpass"
FIREBASE_PROJECT_ID="pitch-pass-prod"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@pitch-pass-prod.iam.gserviceaccount.com"
REDIS_URL="redis://localhost:6379"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# ============ WEB (apps/web/.env.local) ============
NEXT_PUBLIC_FIREBASE_API_KEY="..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="pitch-pass-prod.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="pitch-pass-prod"
NEXT_PUBLIC_FIREBASE_APP_ID="..."
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# ============ MOBILE (apps/mobile/.env) ============
EXPO_PUBLIC_FIREBASE_API_KEY="..."
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN="pitch-pass-prod.firebaseapp.com"
EXPO_PUBLIC_FIREBASE_PROJECT_ID="pitch-pass-prod"
EXPO_PUBLIC_API_URL="http://192.168.x.x:3001"
EXPO_PUBLIC_SOCKET_URL="http://192.168.x.x:3001"
